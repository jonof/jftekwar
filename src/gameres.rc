FILEFLAGS 0
FILEOS VOS_NT_WINDOWS32
FILETYPE VFT_APP
FILESUBTYPE VFT2_UNKNOWN
{
    BLOCK "StringFileInfo"
    {
        BLOCK "080904e4"
        {
            VALUE "CompanyName", "JonoF\0"
            VALUE "FileDescription", "JFTekWar\0"
            VALUE "FileVersion", "0.0\0"
            VALUE "InternalName", "tekwar.exe\0"
